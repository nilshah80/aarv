!examples/*/*.mod
!examples/*/*.sum
!examples/*/*.json
!examples/*/*.html
!examples/*/*.css
!examples/*/*.js
!examples/*/*.md

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
.claude/settings.local.json
